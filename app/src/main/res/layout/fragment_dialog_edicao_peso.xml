<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/dimen_20">

    <ImageView
        android:id="@+id/icone_editar"
        android:layout_width="@dimen/dimen_20"
        android:layout_height="@dimen/dimen_20"
        android:contentDescription="@null"
        android:src="@drawable/edit_24px"
        app:layout_constraintBottom_toBottomOf="@id/texto_titulo_dialog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorPrimary" />

    <TextView
        android:id="@+id/texto_titulo_dialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_8"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/editar_peso_animal"
        android:textColor="?attr/colorOnSurface"
        android:textSize="@dimen/text_14"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/layout_identificador"
        app:layout_constraintEnd_toStartOf="@id/layout_identificador"
        app:layout_constraintStart_toEndOf="@id/icone_editar"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layout_identificador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="@dimen/dimen_14"
            android:layout_height="@dimen/dimen_14"
            android:importantForAccessibility="no"
            android:src="@drawable/tag_24px"
            app:tint="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/texto_identificador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_4"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_12"
            tools:text="0042" />

    </LinearLayout>

    <View
        android:id="@+id/divisor"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/dimen_16"
        android:alpha="0.5"
        android:background="?attr/colorOutlineVariant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_titulo_dialog" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/container_entrada_peso"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_16"
        android:hint="@string/peso_bezerro"
        app:endIconDrawable="@drawable/swap_vert_24px"
        app:endIconMode="custom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divisor"
        app:shapeAppearance="?attr/shapeAppearanceCornerSmall"
        app:startIconDrawable="@drawable/edit_24px">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/entrada_peso_animal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionDone"
            android:digits="0123456789.,"
            android:inputType="numberDecimal" />

    </com.google.android.material.textfield.TextInputLayout>

</androidx.constraintlayout.widget.ConstraintLayout>