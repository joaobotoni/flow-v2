<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cartao_precificacao_bezerro"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/dimen_6"
    app:cardBackgroundColor="?attr/colorSurface"
    app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp">

        <View
            android:id="@+id/accent_bar"
            android:layout_width="3dp"
            android:layout_height="0dp"
            android:background="?attr/colorPrimary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layout_identificador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_16"
            android:layout_marginTop="@dimen/dimen_14"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toEndOf="@+id/accent_bar"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="@dimen/dimen_14"
                android:layout_height="@dimen/dimen_14"
                android:importantForAccessibility="no"
                android:src="@drawable/tag_24px"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/texto_identificador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_4"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_12"
                tools:text="0042" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_peso"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_16"
            android:layout_marginTop="@dimen/dimen_4"
            android:orientation="horizontal"
            app:layout_constraintEnd_toStartOf="@+id/layout_acoes"
            app:layout_constraintStart_toEndOf="@+id/accent_bar"
            app:layout_constraintTop_toBottomOf="@+id/layout_identificador">

            <TextView
                android:id="@+id/texto_valor_peso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_26"
                android:textStyle="bold"
                tools:text="300" />

            <TextView
                android:id="@+id/texto_unidade_peso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_6"
                android:layout_marginBottom="@dimen/dimen_2"
                android:alpha="0.55"
                android:maxLines="1"
                android:text="kg"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_14"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_precos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_16"
            android:layout_marginTop="@dimen/dimen_8"
            android:layout_marginBottom="@dimen/dimen_16"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/accent_bar"
            app:layout_constraintTop_toBottomOf="@+id/layout_peso">

            <TextView
                android:id="@+id/texto_moeda_valor_por_kg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen_2"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/currency_symbol"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_12"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/texto_valor_por_kg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dimen_1"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_16"
                android:textStyle="bold"
                tools:text="8,50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_2"
                android:alpha="0.75"
                android:maxLines="1"
                android:text="/kg"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_12" />

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="@dimen/dimen_10"
                android:alpha="0.2"
                android:background="?attr/colorOnSurfaceVariant"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/texto_moeda_valor_unitario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen_2"
                android:alpha="0.75"
                android:maxLines="1"
                android:text="@string/currency_symbol"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_12"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/texto_valor_unitario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dimen_1"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_16"
                android:textStyle="bold"
                tools:text="2.911,25" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_acoes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/dimen_10"
            android:paddingEnd="@dimen/dimen_10"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_editar"
                style="?attr/materialIconButtonStyle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:icon="@drawable/edit_24px"
                app:iconSize="@dimen/dimen_20"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_excluir"
                style="?attr/materialIconButtonStyle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/dimen_2"
                app:icon="@drawable/delete_24px"
                app:iconSize="@dimen/dimen_20"
                app:iconTint="?attr/colorError" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>