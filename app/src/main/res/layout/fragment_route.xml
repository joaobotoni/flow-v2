<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/divisor_topo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:layout_weight="1"
            android:background="?attr/colorOutline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/label_rota"
            android:textAllCaps="true"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:layout_weight="1"
            android:background="?attr/colorOutline" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linha_cards_rota"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_10"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divisor_topo">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cartao_origem"
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dimen_4"
            android:layout_weight="1"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
            app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/dimen_16">

                <ImageView
                    android:id="@+id/imagem_icone_origem"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/distance_24px"
                    app:tint="?attr/colorOutline" />

                <TextView
                    android:id="@+id/texto_rotulo_origem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_6"
                    android:alpha="0.7"
                    android:text="@string/label_origem"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/text_10"
                    app:layout_constraintBottom_toBottomOf="@id/imagem_icone_origem"
                    app:layout_constraintStart_toEndOf="@id/imagem_icone_origem"
                    app:layout_constraintTop_toTopOf="@id/imagem_icone_origem" />

                <TextView
                    android:id="@+id/texto_cidade_origem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_8"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/text_18"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/imagem_icone_origem"
                    tools:text="Cidade" />

                <TextView
                    android:id="@+id/texto_estado_origem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_1"
                    android:alpha="0.65"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/text_13"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/texto_cidade_origem"
                    tools:text="Estado" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cartao_destino"
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_4"
            android:layout_weight="1"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/dimen_16">

                <ImageView
                    android:id="@+id/imagem_icone_destino"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/distance_24px"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/texto_rotulo_destino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_6"
                    android:alpha="0.7"
                    android:text="@string/label_destino"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="@dimen/text_10"
                    app:layout_constraintBottom_toBottomOf="@id/imagem_icone_destino"
                    app:layout_constraintStart_toEndOf="@id/imagem_icone_destino"
                    app:layout_constraintTop_toTopOf="@id/imagem_icone_destino" />

                <TextView
                    android:id="@+id/texto_cidade_destino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_8"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="@dimen/text_18"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/imagem_icone_destino"
                    tools:text="Cidade" />

                <TextView
                    android:id="@+id/texto_estado_destino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_1"
                    android:alpha="0.65"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="@dimen/text_13"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/texto_cidade_destino"
                    tools:text="Estado" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cartao_distancia"
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_8"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/linha_cards_rota"
        app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/dimen_16"
            android:paddingVertical="@dimen/dimen_14">

            <ImageView
                android:id="@+id/imagem_icone_distancia"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/route_24px"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/texto_rotulo_distancia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_10"
                android:alpha="0.7"
                android:text="@string/label_distancia"
                android:textAllCaps="true"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_10"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/imagem_icone_distancia"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/texto_unidade_distancia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.65"
                android:text="@string/km"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_13"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/texto_valor_distancia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen_4"
                android:text="@string/zero"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_18"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@id/texto_unidade_distancia"
                app:layout_constraintEnd_toStartOf="@id/texto_unidade_distancia" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>